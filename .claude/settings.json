{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruff format \"$CLAUDE_FILE_PATHS\" 2>/dev/null; ruff check --fix --silent \"$CLAUDE_FILE_PATHS\" 2>/dev/null; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q '\\.env'; then echo 'Blocked: .env files are protected from edits' >&2; exit 1; fi"
          }
        ]
      }
    ]
  }
}
